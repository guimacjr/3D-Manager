# URL usada no build do frontend web para apontar a API.
# No compose padrao, /api eh roteado pelo Nginx para o backend.
EXPO_PUBLIC_API_URL=/api

OTEL_SERVICE_NAME=3d-manager-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://host.docker.internal:4318/v1/traces
# OTEL_SDK_DISABLED=false
